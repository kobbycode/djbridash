rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Mixes: Public read, Admin write
    match /mixes/{mixId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Gallery: Public read, Admin write
    match /gallery/{photoId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Events: Public read, Admin write
    match /events/{eventId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Videos (TikTok Showcase): Public read, Admin write
    match /videos/{videoId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Inquiries: Admin read/write, Public write (for contact form)
    match /inquiries/{inquiryId} {
      allow create: if true;
      allow read, update, delete: if isAuthenticated();
    }

    // Hero Slides: Public read, Admin write
    match /hero_slides/{slideId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
  }
}
